### ------------------------------------------------------------
### shortcut help
### ------------------------------------------------------------
bindsym Mod1+h exec ~/.config/sway/scripts/show-help


### ------------------------------------------------------------
### Navigation
### ------------------------------------------------------------

bindsym $mod+h focus left
bindsym $mod+j focus down
bindsym $mod+k focus up
bindsym $mod+l focus right

### ------------------------------------------------------------
### Rectangle-style window management
### ------------------------------------------------------------

# left half
bindsym $mod+Shift+h \
    floating enable, \
    resize set width 50 ppt height 100 ppt, \
    move position 0 ppt 0 ppt

# right half
bindsym $mod+Shift+l \
    floating enable, \
    resize set width 50 ppt height 100 ppt, \
    move position 50 ppt 0 ppt

# top half
bindsym $mod+Shift+k \
    floating enable, \
    resize set width 100 ppt height 50 ppt, \
    move position 0 ppt 0 ppt

# bottom half
bindsym $mod+Shift+j \
    floating enable, \
    resize set width 100 ppt height 50 ppt, \
    move position 0 ppt 50 ppt

# maximize
bindsym $mod+Shift+m \
    floating enable, \
    resize set width 100 ppt height 100 ppt, \
    move position 0 ppt 0 ppt

# centered window
bindsym $mod+c \
    floating enable, \
    resize set width 70 ppt height 80 ppt, \
    move position center

### ------------------------------------------------------------
### Resize mode
### ------------------------------------------------------------

mode "resize" {
    bindsym h resize shrink width 20 px
    bindsym j resize grow height 20 px
    bindsym k resize shrink height 20 px
    bindsym l resize grow width 20 px

    bindsym Return mode "default"
    bindsym Escape mode "default"
}

bindsym $mod+r mode "resize"

### ------------------------------------------------------------
### Screenshots
### ------------------------------------------------------------

# full screen
bindsym Print exec grim ~/Pictures/$(date +'%Y-%m-%d_%H-%M-%S').png

# region -> clipboard
bindsym $mod+Shift+s exec grim -g "$(slurp)" - | wl-copy

### ------------------------------------------------------------
### Reload / exit
### ------------------------------------------------------------

bindsym $mod+Shift+c reload
bindsym $mod+Shift+e exit

### ------------------------------------------------------------
### Notifications / clipboard
### ------------------------------------------------------------

exec mako
exec wl-paste --type text --watch cliphist store
exec wl-paste --type image --watch cliphist store

### ------------------------------------------------------------
### Status bar
### ------------------------------------------------------------

bar {
    status_command while date +'%Y-%m-%d %H:%M:%S'; do sleep 1; done
    position top
}

### ------------------------------------------------------------
### Floating app rules
### ------------------------------------------------------------

for_window [app_id="pavucontrol"] floating enable
for_window [app_id="nm-connection-editor"] floating enable
for_window [title="Picture in picture"] floating enable

### ------------------------------------------------------------
### Idle / lock
### ------------------------------------------------------------

exec swayidle -w \
    timeout 300 'swaylock -f' \
    timeout 600 'swaymsg "output * dpms off"' \
    resume 'swaymsg "output * dpms on"'

### ------------------------------------------------------------
### Mouse
### ------------------------------------------------------------

floating_modifier $mod
