### ------------------------------------------------------------
### Minimal sway config for launcher-centric workflow
### ------------------------------------------------------------

set $mod Mod4
set $term wezterm
set $browser chromium
set $menu fuzzel
set $scripts ~/.config/sway/scripts

### ------------------------------------------------------------
### Environment
### ------------------------------------------------------------


# import sway/wayland environment into systemd user session
exec systemctl --user import-environment \
    DISPLAY \
    WAYLAND_DISPLAY \
    SWAYSOCK \
    XDG_CURRENT_DESKTOP \
    XDG_SESSION_TYPE

# propagate env vars to dbus/systemd activated apps
exec dbus-update-activation-environment --systemd \
    DISPLAY \
    WAYLAND_DISPLAY \
    SWAYSOCK \
    XDG_CURRENT_DESKTOP=sway \
    XDG_SESSION_TYPE=wayland


# toolkits
exec_always {
    export XDG_CURRENT_DESKTOP=sway
    export XDG_SESSION_TYPE=wayland
    export MOZ_ENABLE_WAYLAND=1
    export ELECTRON_OZONE_PLATFORM_HINT=auto
    export QT_QPA_PLATFORM=wayland
    export SDL_VIDEODRIVER=wayland
    export _JAVA_AWT_WM_NONREPARENTING=1
}


### ------------------------------------------------------------
### Appearance
### ------------------------------------------------------------

default_floating_border pixel 2
default_border pixel 2

gaps inner 6
gaps outer 2

font pango:Hack Nerd Font 10

focus_follows_mouse no
mouse_warping none

### ------------------------------------------------------------
### Disable tiling feel
### ------------------------------------------------------------

workspace_layout tabbed

# new windows float by default
for_window [class=".*"] floating enable
for_window [app_id=".*"] floating enable

bindsym $mod+Tab focus next
bindsym $mod+Shift+Tab focus prev

### ------------------------------------------------------------
### Launcher
### ------------------------------------------------------------

# app launcher
bindsym $mod+space exec $menu

# terminal
#bindsym $mod+Return exec $term

### ------------------------------------------------------------
### Application launchers
### ------------------------------------------------------------

# super+1 -> chromium
bindsym $mod+1 exec $scripts/focus-or-launch \
    chromium \
    chromium \
    --ozone-platform-hint=auto

# super+2 -> wezterm
bindsym $mod+2 exec $scripts/focus-or-launch \
    org.wezfurlong.wezterm \
    wezterm

# super+3 -> vscode
bindsym $mod+3 exec $scripts/focus-or-launch \
    code \
    code \
    --ozone-platform-hint=auto

# super+4 -> file manager
bindsym $mod+4 exec $scripts/focus-or-launch \
    thunar

### ------------------------------------------------------------
