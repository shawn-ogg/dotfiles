{
  "title": "Hyper-A to Ctrl-A",
  "rules": [
    {
      "description": "Hyper-a sends Ctrl-a",
      "manipulators": [
        {
          "type": "basic",
          "from": {
            "key_code": "a",
            "modifiers": {
              "mandatory": [
                "left_command",
                "left_control",
                "left_option",
                "left_shift"
              ]
            }
          },
          "to": [
            {
              "key_code": "a",
              "modifiers": [
                "left_control"
              ]
            }
          ]
        }
      ]
    }
  ]
}